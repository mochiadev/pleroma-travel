---
---

<div class="fixed bottom-6 right-6 z-40" x-data="{ open: false }">
  <!-- Options Menu -->
  <div 
    x-show="open" 
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 translate-y-4 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100" 
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
    x-transition:leave-end="opacity-0 translate-y-4 scale-95"
    class="absolute bottom-16 right-0 flex flex-col gap-3 mb-2 w-48 origin-bottom-right"
    x-cloak
  >

    <a href="https://wa.me/233558009078" target="_blank"
      class="flex items-center gap-3 p-3 bg-white rounded-xl shadow-xl border border-slate-100 hover:bg-green-50 transition-colors group">
      <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-white shadow-sm group-hover:scale-110 transition-transform">
        <i class="ph-fill ph-whatsapp-logo text-lg"></i>
      </div>
      <span class="text-sm font-semibold text-slate-700">WhatsApp</span>
    </a>

    <a href="mailto:pleromatravelconsult@gmail.com"
      class="flex items-center gap-3 p-3 bg-white rounded-xl shadow-xl border border-slate-100 hover:bg-red-50 transition-colors group">
      <div class="w-8 h-8 rounded-full bg-red-500 flex items-center justify-center text-white shadow-sm group-hover:scale-110 transition-transform">
        <i class="ph-fill ph-envelope-simple text-lg"></i>
      </div>
      <span class="text-sm font-semibold text-slate-700">Email</span>
    </a>

    <a href="tel:+233558009078"
      class="flex items-center gap-3 p-3 bg-white rounded-xl shadow-xl border border-slate-100 hover:bg-purple-50 transition-colors group">
      <div class="w-8 h-8 rounded-full bg-purple-500 flex items-center justify-center text-white shadow-sm group-hover:scale-110 transition-transform">
        <i class="ph-fill ph-phone text-lg"></i>
      </div>
      <span class="text-sm font-semibold text-slate-700">Call Now</span>
    </a>
  </div>

  <!-- Toggle Button -->
  <button @click="open = !open"
    class="w-14 h-14 bg-gradient-to-r from-purple-600 to-blue-600 rounded-full shadow-lg shadow-purple-500/30 flex items-center justify-center text-white transition-transform hover:scale-105 hover:shadow-purple-500/50 focus:outline-none z-50 relative">
    <i x-show="!open" class="ph-fill ph-chat-circle-dots text-2xl transition-transform duration-300"></i>
    <i x-show="open" class="ph-bold ph-x text-2xl transition-transform duration-300 rotate-90" :class="{ 'rotate-0': open }" x-cloak></i>

    <!-- Pulse effect -->
    <span x-show="!open" class="absolute inset-0 rounded-full animate-ping bg-purple-500 opacity-20"></span>
  </button>
</div>
