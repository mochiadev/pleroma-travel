---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-300 pt-16 pb-8 relative overflow-hidden mt-auto">
  <!-- Background Noise Texture -->
  <div class="absolute inset-0 opacity-5 pointer-events-none noise-bg"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 mb-16">

      <!-- Brand Column -->
      <div class="lg:col-span-4 space-y-8">
        <div class="space-y-6">
          <a href="/" class="flex items-center gap-3">
            <img src="/images/ptc_logo.avif" alt="Pleroma Travel Consult" class="h-12 w-auto brightness-0 invert">
            <div class="flex flex-col leading-tight">
              <span class="font-heading font-bold text-xl tracking-wider text-white">PLEROMA</span>
              <span class="font-heading font-light text-xs tracking-[0.15em] text-slate-400 uppercase">Travel Consult</span>
            </div>
          </a>
          <p class="text-sm leading-relaxed text-slate-400 max-w-sm">
            Your trusted partner for global opportunities. From study abroad to business expansion, we make the world accessible through expertise and integrity.
          </p>
          <div class="flex gap-4">
            <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-purple-600 hover:text-white transition-all duration-300"><i class="ph ph-facebook-logo text-xl"></i></a>
            <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-sky-500 hover:text-white transition-all duration-300"><i class="ph ph-twitter-logo text-xl"></i></a>
            <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all duration-300"><i class="ph ph-linkedin-logo text-xl"></i></a>
            <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-pink-600 hover:text-white transition-all duration-300"><i class="ph ph-instagram-logo text-xl"></i></a>
          </div>
        </div>

        <div class="pt-4 border-t border-slate-800">
          <h6 class="text-white font-bold text-xs uppercase tracking-widest mb-4">Quick Navigation</h6>
          <ul class="flex flex-wrap gap-x-6 gap-y-2 text-xs">
            <li><a href="/" class="hover:text-amber-400 transition-colors">Home</a></li>
            <li><a href="/about" class="hover:text-amber-400 transition-colors">About Us</a></li>
            <li><a href="/services" class="hover:text-amber-400 transition-colors">All Services</a></li>
            <li><a href="/contact" class="hover:text-amber-400 transition-colors">Contact</a></li>
          </ul>
        </div>
      </div>

      <!-- Services Dual Pane -->
      <div class="lg:col-span-5">
        <h5 class="text-white font-bold mb-8 text-center lg:text-left uppercase tracking-widest text-xs border-b border-slate-800 pb-4">Our Services</h5>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6 text-sm">
          <!-- Travel & Visas -->
          <ul class="space-y-3">
            <li><a href="/services/study-abroad" class="hover:text-purple-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-[10px] text-purple-500"></i> Study Abroad</a></li>
            <li><a href="/services/work-permit" class="hover:text-purple-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-[10px] text-purple-500"></i> Work Permits</a></li>
            <li><a href="/services/tourist-visa" class="hover:text-purple-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-[10px] text-purple-500"></i> Tourist Visas</a></li>
            <li><a href="/services/schengen-visa" class="hover:text-purple-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-[10px] text-purple-500"></i> Schengen Visa</a></li>
          </ul>
          <!-- Legal & Business -->
          <ul class="space-y-3">
            <li><a href="/legal-documents#passport" class="hover:text-amber-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-[10px] text-amber-500"></i> Passport Application</a></li>
            <li><a href="/legal-documents#birth-certificate" class="hover:text-amber-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-[10px] text-amber-500"></i> Birth Certificate Reg</a></li>
            <li><a href="/business-support#registration" class="hover:text-amber-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-[10px] text-amber-500"></i> Business Registration</a></li>
            <li><a href="/business-support#consultation" class="hover:text-amber-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-[10px] text-amber-500"></i> Business Consultation</a></li>
          </ul>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="lg:col-span-3">
        <h5 class="text-white font-bold mb-8 uppercase tracking-widest text-xs border-b border-slate-800 pb-4">Contact Us</h5>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <i class="ph-bold ph-map-pin text-amber-500 text-lg mt-0.5"></i>
            <span class="text-slate-400 leading-relaxed">Sowutoum, Accra<br>Greater Accra, Ghana</span>
          </li>
          <li class="flex items-center gap-3">
            <i class="ph-bold ph-phone text-amber-500 text-lg"></i>
            <a href="tel:+233558009078" class="hover:text-white transition-colors">+233 55 800 9078</a>
          </li>
          <li class="flex items-center gap-3">
            <i class="ph-bold ph-envelope-simple text-amber-500 text-lg"></i>
            <a href="mailto:pleromatravelconsult@gmail.com" class="hover:text-white transition-colors text-xs break-all">pleromatravelconsult@gmail.com</a>
          </li>
          <li class="flex items-center gap-3">
            <i class="ph-bold ph-clock text-amber-500 text-lg"></i>
            <span class="text-slate-400">Mon - Fri: 8:00 AM - 5:00 PM</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-8 grid grid-cols-1 md:grid-cols-3 items-center gap-6 text-xs text-slate-500">
      <p class="text-center md:text-left">&copy; {currentYear} Pleroma Travel Consult. All rights reserved.</p>
      
      <p class="text-center">
        Built by <a href="https://fexadigital.com" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-purple-400 font-semibold transition-colors">Fexa Digital</a>
      </p>

      <div class="flex justify-center md:justify-end gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
