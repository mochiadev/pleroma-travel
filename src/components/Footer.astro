---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-300 pt-16 pb-8 relative overflow-hidden mt-auto">
  <!-- Background Noise Texture -->
  <div class="absolute inset-0 opacity-5 pointer-events-none noise-bg"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">

      <!-- Brand Column -->
      <div class="space-y-6">
        <a href="/" class="flex items-center gap-3">
          <img src="/images/ptc_llogo.png" alt="Pleroma Travel Consult" class="h-12 w-auto brightness-0 invert">
          <div class="flex flex-col leading-tight">
            <span class="font-heading font-bold text-xl tracking-wider text-white">PLEROMA</span>
            <span class="font-heading font-light text-xs tracking-[0.15em] text-slate-400 uppercase">Travel Consult</span>
          </div>
        </a>
        <p class="text-sm leading-relaxed text-slate-400">
          Your trusted partner for global opportunities. From study abroad to business expansion, we make the world accessible.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-purple-600 hover:text-white transition-all duration-300"><i class="ph ph-facebook-logo text-xl"></i></a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-sky-500 hover:text-white transition-all duration-300"><i class="ph ph-twitter-logo text-xl"></i></a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all duration-300"><i class="ph ph-linkedin-logo text-xl"></i></a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-pink-600 hover:text-white transition-all duration-300"><i class="ph ph-instagram-logo text-xl"></i></a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h5 class="text-white font-bold mb-6">Quick Links</h5>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="hover:text-amber-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-xs"></i>Home</a></li>
          <li><a href="/about" class="hover:text-amber-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-xs"></i>About Us</a></li>
          <li><a href="/services" class="hover:text-amber-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-xs"></i>All Services</a></li>
          <li><a href="/contact" class="hover:text-amber-400 transition-colors flex items-center gap-2"><i class="ph-bold ph-caret-right text-xs"></i>Contact Us</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h5 class="text-white font-bold mb-6">Services</h5>
        <ul class="space-y-3 text-sm">
          <li><a href="/services/study-abroad" class="hover:text-purple-400 transition-colors">Study Abroad</a></li>
          <li><a href="/services/work-permit" class="hover:text-purple-400 transition-colors">Work Permits</a></li>
          <li><a href="/services/tourist-visa" class="hover:text-purple-400 transition-colors">Tourist Visas</a></li>
          <li><a href="/services/company-registration" class="hover:text-purple-400 transition-colors">Company Registration</a></li>
          <li><a href="/services/business-consultation" class="hover:text-purple-400 transition-colors">Business Consultation</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h5 class="text-white font-bold mb-6">Contact Us</h5>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <i class="ph-bold ph-map-pin text-amber-500 text-lg mt-0.5"></i>
            <span>Sowutoum, Accra<br>Greater Accra, Ghana</span>
          </li>
          <li class="flex items-center gap-3">
            <i class="ph-bold ph-phone text-amber-500 text-lg"></i>
            <a href="tel:+233241234567" class="hover:text-white transition-colors">+233 24 123 4567</a>
          </li>
          <li class="flex items-center gap-3">
            <i class="ph-bold ph-envelope-simple text-amber-500 text-lg"></i>
            <a href="mailto:pleromatravelconsult@gmail.com" class="hover:text-white transition-colors text-xs break-all">pleromatravelconsult@gmail.com</a>
          </li>
          <li class="flex items-center gap-3">
            <i class="ph-bold ph-clock text-amber-500 text-lg"></i>
            <span>Mon - Fri: 8:00 AM - 5:00 PM</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500">
      <p>&copy; {currentYear} Pleroma Travel Consult. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
