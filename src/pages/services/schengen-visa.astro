---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Schengen Visa - Pleroma Travel Consult" activeNav="services">
  <!-- Premium Hero Section -->
  <header class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 bg-slate-900 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0 bg-slate-900">
      <img src="https://images.unsplash.com/photo-1499856871958-5b9627545d1a?auto=format&fit=crop&w=1920&q=80" alt="European Architecture" class="w-full h-full object-cover opacity-50 object-center">
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/70 to-slate-900/30"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-aos="fade-right">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-[2px] bg-sky-500"></div>
          <span class="text-sky-500 font-bold text-xs tracking-widest uppercase">European Travel</span>
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-white mb-6 tracking-tight leading-tight">
          Schengen Visa
        </h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl">
          Expert processing and guidance for your Schengen Area visa application — covering 27 European countries with a single visa.
        </p>
      </div>
    </div>
  </header>

  <!-- Schengen Zone — Bento Layout -->
  <section class="py-16 sm:py-20 lg:py-24 bg-slate-50 relative overflow-hidden">
    <div class="absolute -right-[15%] top-20 w-[40%] h-[60%] bg-sky-200/30 rounded-full blur-[100px] pointer-events-none z-0"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-14 lg:mb-16" data-aos="fade-up">
        <span class="inline-block px-4 py-1 rounded-full bg-white text-sky-600 font-bold text-xs mb-5 tracking-[0.2em] uppercase border border-sky-200 shadow-sm">Schengen Zone</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-slate-900 leading-[1.1] tracking-tight font-heading mb-4 sm:mb-6">
          One Visa, <span class="italic font-light text-slate-500">27 Countries</span>
        </h2>
        <p class="text-base sm:text-lg text-slate-600 font-light">The Schengen visa grants you access to 27 European member states with a single application.</p>
      </div>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-12 gap-4 sm:gap-5 lg:gap-6" data-aos="fade-up" data-aos-delay="100">

        <!-- Image Block with Stats -->
        <div class="sm:col-span-2 md:col-span-5 rounded-2xl sm:rounded-3xl overflow-hidden relative group shadow-xl aspect-[16/10] sm:aspect-auto">
          <img src="/images/study-abroad.jpg" alt="European Travel" class="w-full h-full object-cover min-h-[220px] sm:min-h-[300px] transition-transform duration-[2s] group-hover:scale-110">
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/70 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-5 sm:p-8">
            <div class="text-4xl sm:text-5xl font-heading font-bold text-white mb-1">27<span class="text-sky-400">+</span></div>
            <p class="text-slate-200 text-xs sm:text-sm font-medium uppercase tracking-widest">Countries Accessible</p>
          </div>
        </div>

        <!-- Feature Card 1 — Document Preparation (wide) -->
        <div class="sm:col-span-2 md:col-span-7 bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 lg:p-10 border border-slate-200 shadow-sm hover:shadow-xl hover:border-sky-200 transition-all group">
          <div class="flex items-start gap-4 sm:gap-6">
            <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-xl sm:rounded-2xl bg-sky-50 border border-sky-100 flex items-center justify-center shrink-0 group-hover:bg-sky-600 group-hover:text-white transition-colors text-sky-600">
              <i class="ph-bold ph-files text-2xl sm:text-3xl"></i>
            </div>
            <div class="flex-1">
              <h4 class="text-lg sm:text-xl lg:text-2xl font-bold text-slate-900 mb-2 sm:mb-3">Document Preparation</h4>
              <p class="text-slate-500 text-sm sm:text-base leading-relaxed">Complete assistance with invitation letters, travel insurance, bank statements, and itinerary planning. We handle the heavy lifting so you can focus on planning your trip.</p>
            </div>
          </div>
        </div>

        <!-- Feature Card 2 — Appointment Booking (sky accent) -->
        <div class="md:col-span-4 bg-sky-600 text-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 relative overflow-hidden group">
          <div class="absolute inset-0 noise-bg opacity-10 mix-blend-overlay"></div>
          <div class="absolute -right-12 -bottom-12 w-40 h-40 bg-white/10 rounded-full blur-2xl"></div>
          <div class="relative z-10 h-full flex flex-col justify-between min-h-[160px] sm:min-h-0">
            <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-white/20 flex items-center justify-center mb-5 sm:mb-8 backdrop-blur-sm">
              <i class="ph-bold ph-calendar-check text-xl sm:text-2xl"></i>
            </div>
            <div>
              <h4 class="text-lg sm:text-xl font-bold mb-2">Appointment Booking</h4>
              <p class="text-sky-100 text-sm leading-relaxed">We secure your embassy or VFS appointment at the earliest available slot.</p>
            </div>
          </div>
        </div>

        <!-- Feature Card 3 — Interview Coaching -->
        <div class="md:col-span-4 bg-white rounded-2xl sm:rounded-3xl p-6 sm:p-8 border border-slate-200 shadow-sm hover:shadow-xl hover:border-amber-200 transition-all group">
          <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-amber-50 border border-amber-100 flex items-center justify-center mb-5 sm:mb-8 text-amber-600 group-hover:bg-amber-500 group-hover:text-white transition-colors">
            <i class="ph-bold ph-chats-circle text-xl sm:text-2xl"></i>
          </div>
          <h4 class="text-lg sm:text-xl font-bold text-slate-900 mb-2">Interview Coaching</h4>
          <p class="text-slate-500 text-sm leading-relaxed">Personalized mock interviews to prepare you for consulate questions and build confidence.</p>
        </div>

        <!-- CTA Block -->
        <div class="md:col-span-4 bg-slate-900 rounded-2xl sm:rounded-3xl p-6 sm:p-8 flex flex-col items-center justify-center text-center relative overflow-hidden group min-h-[180px] sm:min-h-0">
          <div class="absolute inset-0 noise-bg opacity-10 mix-blend-overlay"></div>
          <div class="absolute top-0 left-0 w-32 h-32 bg-sky-500/20 rounded-full blur-3xl"></div>
          <div class="relative z-10">
            <p class="text-white font-bold text-base sm:text-lg mb-4">Ready to explore Europe?</p>
            <a href="/apply" class="inline-flex items-center justify-center gap-2 px-6 sm:px-8 py-3 bg-white text-slate-900 font-bold rounded-full hover:bg-sky-50 hover:scale-105 transition-all shadow-lg text-sm w-full sm:w-auto">
              Apply Now <i class="ph-bold ph-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Covered Countries -->
  <section class="py-24 bg-slate-50 border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-aos="fade-up">
        <span class="inline-block px-4 py-1 rounded-full bg-sky-100 text-sky-600 font-bold text-xs mb-4 uppercase tracking-widest">Destinations</span>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Where Can You Travel?</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">A single Schengen visa opens the doors to these 27 member states across Europe.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4" data-aos="fade-up" data-aos-delay="100">
        {[
          { name: 'Austria', code: 'at' }, { name: 'Belgium', code: 'be' }, { name: 'Croatia', code: 'hr' }, { name: 'Czech Republic', code: 'cz' }, { name: 'Denmark', code: 'dk' },
          { name: 'Estonia', code: 'ee' }, { name: 'Finland', code: 'fi' }, { name: 'France', code: 'fr' }, { name: 'Germany', code: 'de' }, { name: 'Greece', code: 'gr' },
          { name: 'Hungary', code: 'hu' }, { name: 'Iceland', code: 'is' }, { name: 'Italy', code: 'it' }, { name: 'Latvia', code: 'lv' }, { name: 'Lithuania', code: 'lt' },
          { name: 'Luxembourg', code: 'lu' }, { name: 'Malta', code: 'mt' }, { name: 'Netherlands', code: 'nl' }, { name: 'Norway', code: 'no' }, { name: 'Poland', code: 'pl' },
          { name: 'Portugal', code: 'pt' }, { name: 'Slovakia', code: 'sk' }, { name: 'Slovenia', code: 'si' }, { name: 'Spain', code: 'es' }, { name: 'Sweden', code: 'se' },
          { name: 'Switzerland', code: 'ch' }, { name: 'Liechtenstein', code: 'li' }
        ].map((c) => (
          <div class="bg-white rounded-xl px-4 py-3 flex items-center justify-center gap-2.5 border border-slate-200 hover:border-sky-300 hover:shadow-md transition-all text-sm font-semibold text-slate-700 hover:text-sky-600">
            <img
              src={`https://flagcdn.com/20x15/${c.code}.png`}
              srcset={`https://flagcdn.com/40x30/${c.code}.png 2x, https://flagcdn.com/60x45/${c.code}.png 3x`}
              width="20"
              height="15"
              alt={c.name}
              class="rounded-sm shadow-sm"
            />
            {c.name}
          </div>
        ))}
      </div>
    </div>
  </section>


  <section class="py-12 sm:py-16 relative overflow-hidden bg-white">
    <!-- Mesh Background (B2 Style) -->
    <div class="absolute inset-0 z-0">
      <div class="absolute -top-[10%] -left-[5%] w-[50%] h-[50%] bg-sky-100/40 rounded-full blur-[100px] animate-pulse"></div>
      <div class="absolute -bottom-[10%] -right-[5%] w-[50%] h-[50%] bg-blue-50/40 rounded-full blur-[100px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-10 sm:mb-12" data-aos="fade-up">
        <span class="inline-block px-3 py-1 rounded-full bg-sky-50 text-sky-600 font-bold text-[10px] tracking-[0.2em] uppercase mb-3 border border-sky-100">Official Requirements</span>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-slate-900 mb-3">Application Checklist</h2>
        <p class="text-slate-500 max-w-2xl mx-auto text-sm sm:text-base">Ensure you have the following documents ready to streamline your application process.</p>
      </div>

      <!-- Ledger List (A Style - No Numbering) -->
      <div class="border-t border-slate-200/60" data-aos="fade-up">
        {[
          { title: 'Valid Passport', desc: 'Must be valid for at least 3 months beyond your planned return date, with 2+ blank pages.' },
          { title: 'Completed Application Form', desc: 'Accurately filled Schengen visa application form — we assist with this.' },
          { title: 'Travel Insurance', desc: 'Minimum coverage of €30,000 for medical emergencies across all Schengen states.' },
          { title: 'Proof of Financial Means', desc: 'Bank statements demonstrating sufficient funds for your stay.' },
          { title: 'Flight & Hotel Reservations', desc: 'Round-trip flight itinerary and accommodation bookings for your entire stay.' },
          { title: 'Passport-Sized Photos', desc: 'Recent biometric photos meeting strict Schengen specifications.' }
        ].map((item) => (
          <div class="group flex items-start gap-4 sm:gap-6 py-4 sm:py-5 border-b border-slate-200/60 hover:bg-white/40 transition-all px-2 sm:px-4 rounded-lg">
            <div class="flex items-center justify-center w-6 h-6 sm:w-7 sm:h-7 rounded-full bg-green-50 text-green-500 shrink-0 mt-1 border border-green-100 group-hover:scale-110 transition-transform">
              <i class="ph-bold ph-check text-xs sm:text-sm"></i>
            </div>
            <div class="flex-1">
              <h4 class="text-base sm:text-lg font-bold text-slate-900 mb-0.5 group-hover:text-sky-700 transition-colors">{item.title}</h4>
              <p class="text-slate-500 text-xs sm:text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 sm:mt-12 text-center" data-aos="fade-up">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3 bg-slate-900 text-white font-bold rounded-xl hover:bg-slate-800 transition-all shadow-xl shadow-slate-900/10 group w-full sm:w-auto">
          Get Expert Guidance <i class="ph-bold ph-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
