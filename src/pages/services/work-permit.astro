---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Work Permits - Pleroma Travel Consult" activeNav="services">
  <!-- Premium Hero Section -->
  <header class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 bg-slate-900 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0 bg-slate-900">
      <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1920&q=80" alt="Global Work Opportunities" class="w-full h-full object-cover opacity-50 object-center">
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/70 to-slate-900/30"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-aos="fade-right">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-[2px] bg-blue-500"></div>
          <span class="text-blue-500 font-bold text-xs tracking-widest uppercase">Career & Employment</span>
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-white mb-6 tracking-tight leading-tight">
          Work Permits
        </h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl">
          Unlock international job opportunities with our comprehensive work permit and career placement guidance.
        </p>
      </div>
    </div>
  </header>

  <!-- Editorial Intro -->
  <section class="py-16 lg:py-20 bg-white relative" id="about">
    <div class="container-custom relative z-10">
      <div class="flex flex-col-reverse lg:flex-row gap-12 lg:gap-16 items-center">
        
        <!-- Content Column (Left) -->
        <div class="lg:w-1/2" data-aos="fade-right">
          <div class="flex items-center gap-4 mb-6">
            <span class="w-12 h-[2px] bg-slate-300"></span>
            <span class="text-slate-500 tracking-[0.2em] text-xs font-bold uppercase">Career Mobility</span>
          </div>
          
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-slate-900 leading-[1.1] tracking-tight font-heading">
            Secure Your <span class="italic font-light text-slate-500">International</span> Work Visa
          </h2>
          
          <p class="text-lg text-slate-600 mb-8 leading-relaxed font-light">
            Navigating corporate immigration laws, securing sponsorships, and gathering documentation can be complex. We alleviate the heavy lifting, crafting a precise strategy tailored to your professional profile.
          </p>

          <div class="space-y-6 border-l border-slate-200 pl-6">
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-slate-900"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Eligibility & Sponsorship</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">We assess your qualifications and align them with regions offering the highest probability of employer sponsorship.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-slate-400"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Strategic Visa Processing</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">Meticulous preparation of your application to ensure absolute compliance with host-country labor laws.</p>
            </div>
          </div>
        </div>

        <!-- Image Column (Right) -->
        <div class="lg:w-1/2 w-full" data-aos="fade-left">
          <div class="w-full aspect-[4/3] sm:aspect-video lg:aspect-[4/3] rounded-2xl overflow-hidden shadow-lg border border-slate-100">
            <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&w=800&q=80" alt="Corporate Professional" class="w-full h-full object-cover">
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Relocation Approach (Asymmetrical Steps) -->
  <section class="py-16 lg:py-20 bg-slate-50 relative overflow-hidden">
    <div class="absolute -left-40 top-40 w-96 h-96 bg-amber-100/40 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
        <span class="inline-block px-4 py-1 rounded-full bg-white text-amber-600 font-bold text-xs mb-4 tracking-[0.2em] uppercase border border-amber-200 shadow-sm">Our Methodology</span>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 leading-[1.1] tracking-tight font-heading mb-4">
          The Employment <span class="italic font-light text-slate-500">Pathway</span>
        </h2>
        <p class="text-base text-slate-600 font-light max-w-2xl mx-auto">From initial credential evaluation to your first day at the new office, our proven framework guarantees a seamless transition.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 relative">
        <!-- Connecting Line for Desktop -->
        <div class="hidden md:block absolute top-20 left-10 right-10 h-px bg-gradient-to-r from-amber-200 via-slate-300 to-amber-200 z-0"></div>

        {[
          { step: '01', title: 'Profile Evaluation', icon: 'ph-file-search', desc: 'Review of your resume to pinpoint ideal global markets.', delay: '0' },
          { step: '02', title: 'Employer Matching', icon: 'ph-handshake', desc: 'Connecting you with verified employers willing to sponsor your visa.', delay: '100' },
          { step: '03', title: 'Immigration Filing', icon: 'ph-stamp', desc: 'Handling all complex legal paperwork and compliance checks.', delay: '200' }
        ].map((item) => (
          <div class="relative z-10 bg-white rounded-3xl p-8 shadow-md border border-slate-100 group hover:-translate-y-1 transition-transform duration-300" data-aos="fade-up" data-aos-delay={item.delay}>
            <div class="text-[4rem] font-heading font-bold text-slate-50 absolute top-2 right-6 pointer-events-none transition-colors duration-500 group-hover:text-amber-50">{item.step}</div>
            <div class="w-14 h-14 rounded-full bg-amber-50 flex items-center justify-center text-amber-600 mb-6 border border-amber-100 relative z-10">
              <i class={`ph-light ${item.icon} text-2xl`}></i>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3 relative z-10">{item.title}</h3>
            <p class="text-slate-600 font-light leading-relaxed text-sm relative z-10">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Requirements -->
  <section class="py-16 lg:py-20 bg-white border-t border-slate-100 relative">
    <div class="container-custom">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        
        <!-- Left Context -->
        <div class="lg:w-1/3" data-aos="fade-right">
          <div class="sticky top-32">
            <span class="inline-flex items-center gap-2 text-blue-600 text-xs font-bold tracking-[0.2em] uppercase mb-4">
              <i class="ph-bold ph-folder-notch-open"></i> Documentation
            </span>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 leading-[1.1] tracking-tight font-heading mb-4">
              Official <span class="italic font-light text-slate-500">Requirements</span>
            </h2>
            <p class="text-base text-slate-600 font-light mb-6">
              A meticulously prepared dossier is the cornerstone of a successful work permit application.
            </p>
          </div>
        </div>

        <!-- Ledger List (Concise, no description) -->
        <div class="lg:w-2/3" data-aos="fade-left">
          <div class="border-t-2 border-slate-900">
            {[
              { title: 'Valid Passport' },
              { title: 'Employment Contract' },
              { title: 'Sponsorship Certificate' },
              { title: 'Proof of Qualifications' },
              { title: 'Police Clearance' },
              { title: 'Medical Examination' }
            ].map((req, i) => (
              <div class="group py-4 sm:py-5 border-b border-slate-200 flex items-center gap-4 sm:gap-6 hover:bg-slate-50 transition-colors px-4 sm:px-6 -mx-4 sm:-mx-6">
                <div class="text-slate-300 font-mono text-sm tracking-widest group-hover:text-blue-500 transition-colors">0{i + 1}</div>
                <h4 class="text-lg sm:text-xl font-bold text-slate-900 font-heading group-hover:text-blue-700 transition-colors m-0">{req.title}</h4>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Mini CTA Section -->
  <section class="py-16 lg:py-20 bg-slate-50 border-t border-slate-100">
    <div class="container-custom">
      <div class="bg-slate-900 rounded-3xl p-8 sm:p-12 flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden shadow-xl" data-aos="fade-up">
        <!-- Atmospheric Background -->
        <div class="absolute inset-0 noise-bg opacity-10 mix-blend-overlay z-0"></div>
        <div class="absolute -left-20 -top-20 w-48 h-48 bg-blue-500 rounded-full blur-3xl opacity-30"></div>
        <div class="absolute -right-20 -bottom-20 w-48 h-48 bg-purple-500 rounded-full blur-3xl opacity-30"></div>
        
        <div class="relative z-10 text-center md:text-left">
          <h2 class="text-2xl sm:text-3xl font-bold text-white mb-2 font-heading tracking-tight">Your Next Role Awaits</h2>
          <p class="text-slate-300 font-light text-sm sm:text-base">Connect with employers actively seeking your expertise.</p>
        </div>
        
        <div class="relative z-10 shrink-0">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-white text-slate-900 font-bold uppercase tracking-widest text-xs sm:text-sm hover:bg-slate-100 hover:scale-105 transition-all shadow-lg rounded-xl">
            Inquire Now <i class="ph-bold ph-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
