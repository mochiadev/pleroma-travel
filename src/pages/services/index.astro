---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ServiceCard from '../../components/ServiceCard.astro';
---

<BaseLayout title="Our Services - Pleroma Travel Consult" activeNav="services">
  <!-- Premium Hero Section -->
  <header class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 bg-slate-900 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0 bg-slate-900">
      <img src="/images/service-hero.avif" alt="Services Hero" class="w-full h-full object-cover opacity-50 object-center">
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/70 to-slate-900/30"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-aos="fade-right">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-[2px] bg-amber-500"></div>
          <span class="text-amber-500 font-bold text-xs tracking-widest uppercase">Expertise & Solutions</span>
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-white mb-6 tracking-tight leading-tight">
          Our Services
        </h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl">
          Comprehensive travel, visa, and business solutions tailored to your global ambitions.
        </p>
      </div>
    </div>
  </header>

  <!-- Essential Services Section -->
  <section class="section-padding bg-slate-50 relative">
    <div class="container-custom relative z-10">
      <div class="text-center mb-16" data-aos="fade-up">
        <span class="inline-block px-4 py-1 rounded-full bg-purple-100 text-purple-600 font-bold text-sm mb-4 tracking-wider uppercase">Expertise</span>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Explore Our Solutions</h2>
        <p class="text-slate-600">Select a category to learn more about how we can help you.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div data-aos="fade-up" data-aos-delay="0">
          <ServiceCard 
            title="Study Visa"
            description="Global university placements with visa success guarantee. Start your academic journey today."
            image="/images/study-abroad.jpg"
            href="/services/study-abroad"
            icon="ph-bold ph-graduation-cap"
            iconColor="purple"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <ServiceCard 
            title="Work Permit"
            description="Verified international job placements with legal authorization and sponsorship support."
            image="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=600&q=80"
            href="/services/work-permit"
            icon="ph-bold ph-briefcase"
            iconColor="blue"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="200">
          <ServiceCard 
            title="Tourist Visa"
            description="Hassle-free travel visas with 98% approval rate for holidays and family visits."
            image="https://images.unsplash.com/photo-1503917988258-f87a78e3c995?auto=format&fit=crop&w=600&q=80"
            href="/services/tourist-visa"
            icon="ph-bold ph-airplane-tilt"
            iconColor="teal"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="300">
          <ServiceCard 
            title="Passport Services"
            description="Fast-track passport processing, renewals, and document assistance."
            image="/images/passport.jpg"
            href="/services/legal-documents#passport"
            icon="ph-bold ph-identification-card"
            iconColor="indigo"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="400">
          <ServiceCard 
            title="Business Setup"
            description="Complete international business registration and compliance services."
            image="/images/bizreg.jpg"
            href="/services/business-support#registration"
            icon="ph-bold ph-buildings"
            iconColor="amber"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="500">
          <ServiceCard 
            title="Birth Certificate"
            description="Application, replacement & legalization services for official documents."
            image="/images/birth.jpg"
            href="/services/legal-documents#birth-certificate"
            icon="ph-bold ph-file-text"
            iconColor="rose"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <!-- Left Pane: Illustration & Intro -->
        <div data-aos="fade-right" class="sticky top-24">
          <span class="text-amber-500 font-bold tracking-wider uppercase text-xs mb-4 block">Got Questions?</span>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 leading-[1.1] tracking-tight font-heading">We Have the <span class="italic font-light text-slate-500">Answers</span></h2>
          <p class="text-slate-600 mb-10 text-lg font-light">Whether you're curious about study abroad placements, visa requirements, or language proficiency, find all the details you need right here.</p>
          <img src="/images/faq_illus.svg" alt="FAQ Illustration" class="w-full max-w-sm mx-auto lg:mx-0 drop-shadow-sm" />
        </div>

        <!-- Right Pane: Accordions -->
        <div x-data="{ active: null }" class="space-y-4" data-aos="fade-left">
          {[
            {
              q: 'Do you guarantee visa approval?',
              a: 'No agency can guarantee visa approval as it is the sole discretion of the embassy. However, our expertise significantly increases your chances of success.'
            },
            {
              q: 'Do you assist with scholarships and financial aid?',
              a: 'Yes! We actively guide our students on available scholarship opportunities and assist in preparing compelling scholarship applications to help reduce the financial burden of studying overseas.'
            },
            {
              q: 'Can I work while studying abroad?',
              a: 'In most popular study destinations like the UK, Canada, and Australia, international students are permitted to work part-time (usually up to 20 hours per week) during academic terms and full-time during holidays. We will brief you on the specific work rights for your chosen country.'
            },
            {
              q: 'Do I need to take the IELTS or TOEFL?',
              a: 'English language requirements vary by university and country. While many institutions require IELTS or TOEFL, some may waive these requirements based on your previous education or offer alternative testing options. We will advise you based on your specific profile.'
            }
          ].map((item, index) => (
            <div class="bg-slate-50 rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:border-amber-200 transition-colors">
              <button @click={`active = (active === ${index} ? null : ${index})`}
                class="w-full flex items-center justify-between p-6 text-left font-bold text-slate-900 focus:outline-none">
                {item.q}
                <i class="ph-bold ph-caret-down transition-transform duration-300 text-amber-500" :class={`{ 'rotate-180': active === ${index} }`}></i>
              </button>
              <div x-show={`active === ${index}`} x-collapse x-cloak>
                <div class="p-6 pt-0 text-slate-600 text-sm leading-relaxed border-t border-slate-200/50 mt-2">
                  {item.a}
                </div>
              </div>
            </div>
          ))}
        </div>
        
      </div>
    </div>
  </section>
</BaseLayout>
