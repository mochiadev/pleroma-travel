---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Study Abroad - Pleroma Travel Consult" activeNav="services">
  <!-- Premium Hero Section -->
  <header class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 bg-slate-900 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0 bg-slate-900">
      <img src="/images/student.webp" alt="Study Abroad" class="w-full h-full object-cover opacity-50 object-center">
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/70 to-slate-900/30"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-aos="fade-right">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-[2px] bg-purple-500"></div>
          <span class="text-purple-500 font-bold text-xs tracking-widest uppercase">Global Education</span>
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-white mb-6 tracking-tight leading-tight">
          Study Abroad
        </h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl">
          Unlock global education opportunities with our expert admissions and student visa guidance.
        </p>
      </div>
    </div>
  </header>

  <!-- Global Education Intro -->
  <section class="py-16 lg:py-20 bg-white relative" id="about">
    <div class="container-custom relative z-10">
      <div class="flex flex-col-reverse lg:flex-row gap-12 lg:gap-16 items-center">
        
        <!-- Content Column (Left) -->
        <div class="lg:w-1/2" data-aos="fade-right">
          <div class="flex items-center gap-4 mb-6">
            <span class="w-12 h-[2px] bg-purple-300"></span>
            <span class="text-purple-500 tracking-[0.2em] text-xs font-bold uppercase">Global Education</span>
          </div>
          
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-slate-900 leading-[1.1] tracking-tight font-heading">
            Turn Your <span class="italic font-light text-slate-500">Dream</span> Into Reality
          </h2>
          
          <p class="text-lg text-slate-600 mb-8 leading-relaxed font-light">
            Studying overseas is one of the most transformative experiences a student can have. We simplify the complex admission process, helping you secure a place at your preferred university without the stress.
          </p>

          <div class="space-y-6 border-l border-slate-200 pl-6">
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-purple-600"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">University Placement</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">We match your academic profile with universities that fit your goals and budget.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-amber-400"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Visa Guidance</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">From application to interview preparation, we ensure your visa journey is smooth.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-blue-500"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Post-Arrival Support</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">We assist with accommodation setup, airport pickup, and orientation.</p>
            </div>
          </div>
        </div>

        <!-- Image Column (Right) -->
        <div class="lg:w-1/2 w-full" data-aos="fade-left">
          <div class="w-full aspect-[4/3] sm:aspect-video lg:aspect-[4/3] rounded-2xl overflow-hidden shadow-lg border border-slate-100">
            <img src="/images/mates-uni.jpg" alt="Education" class="w-full h-full object-cover">
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Our Approach (Text-Heavy Asymmetrical Steps) -->
  <section class="py-16 lg:py-20 bg-slate-50 relative overflow-hidden">
    <div class="absolute -right-40 top-40 w-96 h-96 bg-purple-100/40 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="container-custom relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
        <span class="inline-block px-4 py-1 rounded-full bg-white text-purple-600 font-bold text-xs mb-4 tracking-[0.2em] uppercase border border-purple-200 shadow-sm">Our Approach</span>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 leading-[1.1] tracking-tight font-heading mb-4">
          Making it Feel Like a <span class="italic font-light text-slate-500">Breeze</span>
        </h2>
        <p class="text-base text-slate-600 font-light max-w-2xl mx-auto">We replace the stress of international applications with a clear, guided path to success.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 relative">
        <!-- Connecting Line for Desktop -->
        <div class="hidden lg:block absolute top-20 left-10 right-10 h-px bg-gradient-to-r from-purple-200 via-slate-300 to-purple-200 z-0"></div>

        {[
          { 
            step: '01', 
            title: 'Navigating the Maze', 
            icon: 'ph-compass', 
            desc: "Applying to universities across the globe can feel like navigating a maze blindfolded. Between confusing admission requirements, looming deadlines, and the daunting visa process, it's easy to feel overwhelmed. That's where we step in.", 
            delay: '0' 
          },
          { 
            step: '02', 
            title: 'A Guided Path', 
            icon: 'ph-map-trifold', 
            desc: "At Pleroma Travel Consult, we replace the stress with a clear, guided path. From our very first conversation, we take the time to deeply understand your academic goals, budget constraints, and career ambitions. We don't just hand you a list of schools; we collaboratively handpick the institutions where you'll thrive.", 
            delay: '100' 
          },
          { 
            step: '03', 
            title: 'The Heavy Lifting', 
            icon: 'ph-backpack', 
            desc: "Once you've chosen your dream destination, our team meticulously handles the heavy lifting. We help you polish your applications, ensure every document is flawlessly prepared, and submit your requests right on time. And when the acceptance letters roll in, we stand by your side through every step of the visa application and interview preparation. We treat your international education journey as if it were our own.", 
            delay: '200' 
          }
        ].map((item) => (
          <div class="relative z-10 bg-white rounded-3xl p-8 shadow-md border border-slate-100 group hover:-translate-y-1 transition-transform duration-300" data-aos="fade-up" data-aos-delay={item.delay}>
            <div class="text-[4rem] font-heading font-bold text-slate-50 absolute top-2 right-6 pointer-events-none transition-colors duration-500 group-hover:text-purple-50">{item.step}</div>
            <div class="w-14 h-14 rounded-full bg-purple-50 flex items-center justify-center text-purple-600 mb-6 border border-purple-100 relative z-10">
              <i class={`ph-light ${item.icon} text-2xl`}></i>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3 relative z-10">{item.title}</h3>
            <p class="text-slate-600 font-light leading-relaxed text-sm relative z-10">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Requirements -->
  <section class="py-16 lg:py-20 bg-white border-t border-slate-100 relative">
    <div class="container-custom">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        
        <!-- Left Context -->
        <div class="lg:w-1/3" data-aos="fade-right">
          <div class="sticky top-32">
            <span class="inline-flex items-center gap-2 text-purple-600 text-xs font-bold tracking-[0.2em] uppercase mb-4">
              <i class="ph-bold ph-folder-notch-open"></i> Documentation
            </span>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 leading-[1.1] tracking-tight font-heading mb-4">
              Official <span class="italic font-light text-slate-500">Requirements</span>
            </h2>
            <p class="text-base text-slate-600 font-light mb-6">
              A meticulously prepared dossier is the cornerstone of a successful university and student visa application.
            </p>
          </div>
        </div>

        <!-- Ledger List (Concise, no description) -->
        <div class="lg:w-2/3" data-aos="fade-left">
          <div class="border-t-2 border-slate-900">
            {[
              { title: 'Valid Passport' },
              { title: 'Academic Transcripts & Certificates' },
              { title: 'Language Proficiency (IELTS/TOEFL)' },
              { title: 'Statement of Purpose (SOP)' },
              { title: 'Letters of Recommendation' },
              { title: 'Proof of Financial Support' }
            ].map((req, i) => (
              <div class="group py-4 sm:py-5 border-b border-slate-200 flex items-center gap-4 sm:gap-6 hover:bg-slate-50 transition-colors px-4 sm:px-6 -mx-4 sm:-mx-6">
                <div class="text-slate-300 font-mono text-sm tracking-widest group-hover:text-purple-500 transition-colors">0{i + 1}</div>
                <h4 class="text-lg sm:text-xl font-bold text-slate-900 font-heading group-hover:text-purple-700 transition-colors m-0">{req.title}</h4>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Mini CTA Section (Inherited Style) -->
  <section class="py-16 lg:py-20 bg-slate-50 border-t border-slate-100">
    <div class="container-custom">
      <div class="bg-slate-900 rounded-3xl p-8 sm:p-12 flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden shadow-xl" data-aos="fade-up">
        <div class="absolute inset-0 noise-bg opacity-10 mix-blend-overlay z-0"></div>
        <div class="absolute -left-20 -top-20 w-48 h-48 bg-purple-500 rounded-full blur-3xl opacity-30"></div>
        <div class="absolute -right-20 -bottom-20 w-48 h-48 bg-blue-500 rounded-full blur-3xl opacity-30"></div>
        
        <div class="relative z-10 text-center md:text-left">
          <h2 class="text-2xl sm:text-3xl font-bold text-white mb-2 font-heading tracking-tight">Begin Your Journey</h2>
          <p class="text-slate-300 font-light text-sm sm:text-base">Speak with an advisor to map out your study abroad plan.</p>
        </div>
        
        <div class="relative z-10 shrink-0">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-white text-slate-900 font-bold uppercase tracking-widest text-xs sm:text-sm hover:bg-slate-100 hover:scale-105 transition-all shadow-lg rounded-xl">
            Book Consultation <i class="ph-bold ph-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
