---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Booking Consultation - Pleroma Travel Consult" activeNav="booking">
  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-slate-900">
    <div class="absolute inset-0 z-0">
      <img src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=1920&q=80" class="w-full h-full object-cover" alt="Booking Consultation">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-slate-900/60"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10 text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 font-heading" data-aos="fade-up">Book Your <span class="text-amber-400">Consultation</span></h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto mb-10" data-aos="fade-up" data-aos-delay="100">Get expert guidance for your international job opportunities and travel plans. Our consultants are ready to help you navigate the process.</p>
      <div class="flex flex-wrap justify-center gap-4" data-aos="fade-up" data-aos-delay="200">
        <a href="#calendly-booking" class="btn-glow px-8 py-3 rounded-full font-bold">Book Now</a>
        <a href="#booking-faq" class="px-8 py-3 rounded-full font-bold text-white border border-white/30 hover:bg-white/10 transition-colors">View FAQ</a>
      </div>
    </div>
  </section>

  <!-- Calendly Booking Widget & Preparation Guide -->
  <section id="calendly-booking" class="py-24 bg-white">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="text-center mb-16" data-aos="fade-up">
        <span class="inline-block px-4 py-1 rounded-full bg-purple-100 text-purple-600 font-bold text-xs mb-4 uppercase tracking-widest">Schedule</span>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Select a Date & Time</h2>
        <p class="text-slate-600">Find a time that works best for you and schedule a session with our experts.</p>
      </div>

      <div class="grid lg:grid-cols-12 gap-12">
        <!-- Calendly Widget Column -->
        <div class="lg:col-span-7" data-aos="fade-right">
          <div class="calendly-inline-widget rounded-2xl overflow-hidden border border-slate-200 shadow-sm" data-url="https://calendly.com/pleromatravelconsult/30min" style="min-width:320px;height:700px;"></div>
          <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
          <div class="text-center mt-6">
            <p class="text-slate-500">Don't see a time that works? <a href="/contact" class="text-purple-600 font-bold hover:underline">Contact us</a> to arrange an alternative.</p>
          </div>
        </div>

        <!-- Preparation Guide Column -->
        <div class="lg:col-span-5" data-aos="fade-left">
          <div class="bg-slate-50 p-8 rounded-3xl h-full border border-slate-100 shadow-sm">
            <h3 class="text-2xl font-bold text-slate-900 mb-8 flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center shrink-0">
                <i class="ph-bold ph-calendar-check text-xl"></i>
              </div>
              Your Appointment Guide
            </h3>

            <div class="space-y-8">
              <!-- Step 1 -->
              <div>
                <h4 class="text-lg font-bold text-slate-900 flex items-center gap-3 mb-4">
                  <span class="w-8 h-8 rounded-full bg-purple-600 text-white flex items-center justify-center text-sm shrink-0">1</span>
                  Before Your Appointment
                </h4>
                <ul class="space-y-3 pl-11 text-slate-600 text-sm">
                  <li class="flex items-start gap-2">
                    <i class="ph-fill ph-check-circle text-green-500 mt-1 shrink-0"></i>
                    <span>Prepare your questions in advance.</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <i class="ph-fill ph-check-circle text-green-500 mt-1 shrink-0"></i>
                    <span>Gather relevant documents. <a href="/contact" class="text-purple-600 hover:underline">Contact us to find out.</a></span>
                  </li>
                  <li class="flex items-start gap-2">
                    <i class="ph-fill ph-check-circle text-green-500 mt-1 shrink-0"></i>
                    <span>Test your internet connection and webcam.</span>
                  </li>
                </ul>
              </div>

              <!-- Step 2 -->
              <div>
                <h4 class="text-lg font-bold text-slate-900 flex items-center gap-3 mb-4">
                  <span class="w-8 h-8 rounded-full bg-purple-600 text-white flex items-center justify-center text-sm shrink-0">2</span>
                  When Your Appointment Starts
                </h4>
                <ul class="space-y-3 pl-11 text-slate-600 text-sm">
                  <li class="flex items-start gap-2">
                    <i class="ph-fill ph-arrow-circle-right text-purple-600 mt-1 shrink-0"></i>
                    <span>Join 5 minutes early using the Zoom link in your email.</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <i class="ph-fill ph-arrow-circle-right text-purple-600 mt-1 shrink-0"></i>
                    <span>Have a notepad ready for important notes.</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <i class="ph-fill ph-arrow-circle-right text-purple-600 mt-1 shrink-0"></i>
                    <span>Ensure you're in a quiet, well-lit space.</span>
                  </li>
                </ul>
              </div>

              <!-- Info Alert -->
              <div class="bg-blue-50 border border-blue-100 rounded-xl p-5 mt-8 flex gap-4 items-start">
                <i class="ph-fill ph-info text-blue-600 text-2xl shrink-0"></i>
                <div class="text-sm text-blue-900">
                  <strong class="block mb-1">Need to reschedule?</strong>
                  You can change your appointment up to 24 hours in advance using the link in your confirmation email.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="booking-faq" class="py-24 bg-slate-50 border-t border-slate-100">
    <div class="container mx-auto px-6 max-w-3xl">
      <div class="text-center mb-16" data-aos="fade-up">
        <span class="inline-block px-4 py-1 rounded-full bg-purple-100 text-purple-600 font-bold text-xs mb-4 uppercase tracking-widest">Help</span>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Frequently Asked Questions</h2>
        <p class="text-slate-600">Find answers to common questions about our consultation services.</p>
      </div>

      <div class="space-y-4" x-data="{ active: null }">
        <!-- FAQ 1 -->
        <div class="border border-slate-200 rounded-xl overflow-hidden bg-white shadow-sm" data-aos="fade-up">
          <button @click="active = active === 1 ? null : 1" class="w-full flex items-center justify-between p-6 text-left hover:bg-slate-50 transition-colors focus:outline-none">
            <span class="font-bold text-slate-900">What payment methods do you accept?</span>
            <i class="ph-bold ph-caret-down text-2xl text-purple-600 transition-transform duration-300" :class="active === 1 ? 'rotate-180' : ''"></i>
          </button>
          <div x-show="active === 1" x-collapse x-cloak>
            <div class="p-6 pt-0 text-slate-600">
              We accept all major credit cards (Visa, Mastercard, American Express), and mobile money payments (MTN, Telecel and AirtelTigo). Payment is required at the time of booking to secure your appointment.
            </div>
          </div>
        </div>

        <!-- FAQ 2 -->
        <div class="border border-slate-200 rounded-xl overflow-hidden bg-white shadow-sm" data-aos="fade-up">
          <button @click="active = active === 2 ? null : 2" class="w-full flex items-center justify-between p-6 text-left hover:bg-slate-50 transition-colors focus:outline-none">
            <span class="font-bold text-slate-900">How do the video consultations work?</span>
            <i class="ph-bold ph-caret-down text-2xl text-purple-600 transition-transform duration-300" :class="active === 2 ? 'rotate-180' : ''"></i>
          </button>
          <div x-show="active === 2" x-collapse x-cloak>
            <div class="p-6 pt-0 text-slate-600">
              After booking, you'll receive a confirmation email with a Zoom link for your consultation. At your scheduled time, simply click the link to join the video call. We recommend testing your audio and video beforehand and having any relevant documents ready to share.
            </div>
          </div>
        </div>

        <!-- FAQ 3 -->
        <div class="border border-slate-200 rounded-xl overflow-hidden bg-white shadow-sm" data-aos="fade-up">
          <button @click="active = active === 3 ? null : 3" class="w-full flex items-center justify-between p-6 text-left hover:bg-slate-50 transition-colors focus:outline-none">
            <span class="font-bold text-slate-900">Can I reschedule my consultation?</span>
            <i class="ph-bold ph-caret-down text-2xl text-purple-600 transition-transform duration-300" :class="active === 3 ? 'rotate-180' : ''"></i>
          </button>
          <div x-show="active === 3" x-collapse x-cloak>
            <div class="p-6 pt-0 text-slate-600">
              Yes, you can reschedule up to 24 hours before your appointment. Simply use the link in your confirmation email to choose a new time. Rescheduling within 24 hours may be subject to availability.
            </div>
          </div>
        </div>

        <!-- FAQ 4 -->
        <div class="border border-slate-200 rounded-xl overflow-hidden bg-white shadow-sm" data-aos="fade-up">
          <button @click="active = active === 4 ? null : 4" class="w-full flex items-center justify-between p-6 text-left hover:bg-slate-50 transition-colors focus:outline-none">
            <span class="font-bold text-slate-900">Do you guarantee job placement or visa approval?</span>
            <i class="ph-bold ph-caret-down text-2xl text-purple-600 transition-transform duration-300" :class="active === 4 ? 'rotate-180' : ''"></i>
          </button>
          <div x-show="active === 4" x-collapse x-cloak>
            <div class="p-6 pt-0 text-slate-600">
              While we provide expert guidance to improve your chances, we cannot guarantee job placement or visa approval as these decisions are made by employers and government authorities. Our service is designed to give you the best possible preparation and strategy for your international job search and visa application.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 bg-white border-t border-slate-100">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="text-center mb-16" data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">What Our Clients Say</h2>
        <p class="text-slate-600">Hear from travelers who've used our consultation services.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Testimonial 1 -->
        <div class="bg-slate-50 p-8 rounded-3xl border border-slate-100 relative" data-aos="fade-up">
          <i class="ph-fill ph-quotes text-4xl text-purple-200 absolute top-6 right-6"></i>
          <p class="text-slate-700 italic mb-8 relative z-10">"The consultation was incredibly helpful. I got clear guidance on which countries would be best for my skills and how to approach the job search."</p>
          <div class="flex items-center gap-4">
            <img src="https://randomuser.me/api/portraits/women/32.jpg" alt="Sarah K." class="w-12 h-12 rounded-full object-cover">
            <div>
              <h6 class="font-bold text-slate-900">Sarah K.</h6>
              <span class="text-sm text-slate-500">Canada Work Visa</span>
            </div>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="bg-slate-50 p-8 rounded-3xl border border-slate-100 relative" data-aos="fade-up" data-aos-delay="100">
          <i class="ph-fill ph-quotes text-4xl text-amber-200 absolute top-6 right-6"></i>
          <p class="text-slate-700 italic mb-8 relative z-10">"The resume review was worth every penny. I landed 3 interviews within a month of implementing the consultant's suggestions."</p>
          <div class="flex items-center gap-4">
            <img src="https://randomuser.me/api/portraits/men/45.jpg" alt="Michael T." class="w-12 h-12 rounded-full object-cover">
            <div>
              <h6 class="font-bold text-slate-900">Michael T.</h6>
              <span class="text-sm text-slate-500">UK Work Visa</span>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="bg-slate-50 p-8 rounded-3xl border border-slate-100 relative" data-aos="fade-up" data-aos-delay="200">
          <i class="ph-fill ph-quotes text-4xl text-teal-200 absolute top-6 right-6"></i>
          <p class="text-slate-700 italic mb-8 relative z-10">"I was overwhelmed by the visa process, but my consultant broke it down into manageable steps. I'm now happily working in Germany!"</p>
          <div class="flex items-center gap-4">
            <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="Amina B." class="w-12 h-12 rounded-full object-cover">
            <div>
              <h6 class="font-bold text-slate-900">Amina B.</h6>
              <span class="text-sm text-slate-500">Germany Work Visa</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
