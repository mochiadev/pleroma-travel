---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Pleroma Travel Consult" activeNav="home" heroMode={true}>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- HERO — Full-Bleed Cinematic Carousel                      -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section
    class="relative w-full h-[70vh] md:h-[80vh] lg:h-screen overflow-hidden"
    x-data="{
      active: 0,
      total: 4,
      init() { setInterval(() => this.next(), 7000) },
      next() { this.active = (this.active + 1) % this.total },
      prev() { this.active = (this.active - 1 + this.total) % this.total },
      goto(i) { this.active = i }
    }"
  >
    <!-- Background Slides -->
    <div class="absolute inset-0">
      {[
        { src: '/images/index-hero.webp',  alt: 'Travel abroad' },
        { src: '/images/index-hero1.jpg',  alt: 'Business setup' },
        { src: '/images/index-hero2.jpeg', alt: 'New journey' },
        { src: '/images/index-hero3.webp', alt: 'Global reach' },
      ].map((img, i) => (
        <div
          class="absolute inset-0 w-full h-full"
          x-show={`active === ${i}`}
          x-transition:enter="transition-opacity duration-[1200ms] ease-out"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition-opacity duration-[800ms] ease-in"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
        >
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover scale-105"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        </div>
      ))}
      <!-- Gradient Overlays -->
      <div class="absolute inset-0 bg-gradient-to-b from-slate-900/70 via-slate-900/50 to-slate-900/90 z-10"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/80 via-transparent to-transparent z-10"></div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-20 h-full flex items-center pt-16 lg:pt-20">
      <div class="container-custom w-full">
        <!-- Grid stack: both slides occupy the same cell so they overlap without absolute positioning -->
        <div class="grid max-w-3xl" style="grid-template-areas:'stack'">

          <!-- Slide 1 Text -->
          <div
            style="grid-area:stack"
            x-show="active === 0 || active === 2"
            x-transition:enter="transition duration-700 ease-out delay-200"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition duration-300 ease-in"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
          >
            <p class="text-amber-400 text-[10px] sm:text-xs md:text-sm font-bold tracking-[0.2em] sm:tracking-[0.25em] uppercase mb-3 md:mb-5">
              <span class="inline-block w-6 sm:w-8 h-px bg-amber-400 mr-2 sm:mr-3 align-middle"></span>Travel &amp; Immigration
            </p>
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-heading font-bold text-white leading-[1.1] tracking-tight mb-3 sm:mb-4 md:mb-6">
              Your Journey Abroad<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-orange-400">Starts Here</span>
            </h1>
            <p class="text-slate-300 text-sm sm:text-base md:text-lg lg:text-xl leading-relaxed max-w-xl mb-5 sm:mb-6 md:mb-8 lg:mb-10">
              Seamless visa processing, verified job placements, and end-to-end relocation support.
            </p>
            <div class="flex flex-wrap gap-3 sm:gap-4">
              <Button href="/contact" variant="glow" class="px-5 sm:px-8 py-2.5 sm:py-3.5 text-xs sm:text-sm uppercase tracking-widest">Get Started</Button>
              <Button href="/services" variant="glass" class="px-5 sm:px-8 py-2.5 sm:py-3.5 text-xs sm:text-sm uppercase tracking-widest">Our Services</Button>
            </div>
          </div>

          <!-- Slide 2 Text -->
          <div
            style="grid-area:stack"
            x-show="active === 1 || active === 3"
            x-cloak
            x-transition:enter="transition duration-700 ease-out delay-200"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition duration-300 ease-in"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
          >
            <p class="text-cyan-400 text-[10px] sm:text-xs md:text-sm font-bold tracking-[0.2em] sm:tracking-[0.25em] uppercase mb-3 md:mb-5">
              <span class="inline-block w-6 sm:w-8 h-px bg-cyan-400 mr-2 sm:mr-3 align-middle"></span>Business &amp; Compliance
            </p>
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-heading font-bold text-white leading-[1.1] tracking-tight mb-3 sm:mb-4 md:mb-6">
              Business Registration<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-blue-400">Made Simple</span>
            </h1>
            <p class="text-slate-300 text-sm sm:text-base md:text-lg lg:text-xl leading-relaxed max-w-xl mb-5 sm:mb-6 md:mb-8 lg:mb-10">
              Tailored company registration, compliance consulting, and corporate structuring across borders.
            </p>
            <div class="flex flex-wrap gap-3 sm:gap-4">
              <Button href="/business-support" variant="glow" class="from-cyan-600 to-blue-600 px-5 sm:px-8 py-2.5 sm:py-3.5 text-xs sm:text-sm uppercase tracking-widest">Learn More</Button>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Bottom Bar: Indicators + Arrows -->
    <div class="absolute bottom-0 left-0 right-0 z-30 pointer-events-none">
      <div class="container-custom flex items-center justify-between py-4 md:py-6 lg:py-8">

        <!-- Progress Indicators -->
        <div class="flex items-center gap-3 pointer-events-auto">
          <template x-for="i in 4">
            <button
              @click="goto(i - 1)"
              class="relative h-1 rounded-full overflow-hidden transition-all duration-500 focus:outline-none"
              :class="active === i - 1 ? 'w-12 bg-white/30' : 'w-6 bg-white/15 hover:bg-white/25'"
            >
              <div
                class="absolute inset-y-0 left-0 bg-white rounded-full"
                :class="active === i - 1 ? 'animate-[progress_7s_linear]' : ''"
                :style="active === i - 1 ? 'width: 100%' : 'width: 0'"
              ></div>
            </button>
          </template>
        </div>

        <!-- Arrow Controls -->
        <div class="flex items-center gap-3 pointer-events-auto">
          <button @click="prev()" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:text-white hover:border-white/50 transition-all focus:outline-none">
            <i class="ph-bold ph-caret-left text-sm"></i>
          </button>
          <button @click="next()" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:text-white hover:border-white/50 transition-all focus:outline-none">
            <i class="ph-bold ph-caret-right text-sm"></i>
          </button>
        </div>

      </div>
    </div>
  </section>

  <!-- Essential Services Section -->
  <section class="section-padding bg-slate-50 relative">
    <div class="container-custom relative z-10">
      <SectionHeading 
        title="Our Essential" 
        highlight="Services" 
        description="Streamlined solutions for your international needs, from visas to business registration."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div data-aos="fade-up" data-aos-delay="0">
          <ServiceCard 
            title="Study Visa"
            description="Global university placements with visa success guarantee. Start your academic journey today."
            image="/images/study-abroad.jpg"
            href="/services/study-abroad"
            icon="ph-bold ph-graduation-cap"
            iconColor="purple"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <ServiceCard 
            title="Work Permit"
            description="Verified international job placements with legal authorization and sponsorship support."
            image="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=600&q=80"
            href="/services/work-permit"
            icon="ph-bold ph-briefcase"
            iconColor="blue"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="200">
          <ServiceCard 
            title="Tourist Visa"
            description="Hassle-free travel visas with 98% approval rate for holidays and family visits."
            image="https://images.unsplash.com/photo-1503917988258-f87a78e3c995?auto=format&fit=crop&w=600&q=80"
            href="/services/tourist-visa"
            icon="ph-bold ph-airplane-tilt"
            iconColor="teal"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="300">
          <ServiceCard 
            title="Passport Services"
            description="Fast-track passport processing, renewals, and document assistance."
            image="/images/passport.jpg"
            href="/legal-documents#passport"
            icon="ph-bold ph-identification-card"
            iconColor="indigo"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="400">
          <ServiceCard 
            title="Business Setup"
            description="Complete international business registration and compliance services."
            image="/images/bizreg.jpg"
            href="/business-support#registration"
            icon="ph-bold ph-buildings"
            iconColor="amber"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="500">
          <ServiceCard 
            title="Birth Certificate"
            description="Application, replacement & legalization services for official documents."
            image="/images/birth.jpg"
            href="/legal-documents#birth-certificate"
            icon="ph-bold ph-file-text"
            iconColor="rose"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Pleroma (Editorial / Asymmetrical) -->
  <section class="py-24 lg:py-32 relative bg-white overflow-hidden border-t border-slate-100">
    <div class="container-custom relative z-10">
      
      <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 mb-20 items-end">
        <div class="lg:w-1/2" data-aos="fade-right">
          <span class="inline-block px-4 py-1 rounded-full bg-slate-100 text-slate-800 font-bold text-xs mb-6 tracking-[0.2em] uppercase border border-slate-200">The Pleroma Standard</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 leading-[1.1] tracking-tight font-heading">
            Excellence <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-indigo-600 italic font-light">Without</span> Compromise
          </h2>
        </div>
        <div class="lg:w-1/2 lg:pl-12 border-l border-slate-200" data-aos="fade-left">
          <p class="text-xl text-slate-600 font-light leading-relaxed">
            We don't just process applications; we architect futures. Our meticulous attention to detail ensures that your global transition is as seamless as it is successful.
          </p>
        </div>
      </div>

      <!-- Asymmetrical Bento / Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8 auto-rows-[minmax(250px,auto)]">
        
        <!-- Large Featured Block -->
        <div class="md:col-span-12 lg:col-span-7 bg-slate-900 text-white rounded-3xl p-10 lg:p-14 relative overflow-hidden group" data-aos="fade-up">
          <div class="absolute inset-0 opacity-20 noise-bg mix-blend-overlay"></div>
          <div class="absolute top-0 right-0 w-64 h-64 bg-cyan-500/20 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-700"></div>
          <div class="relative z-10 h-full flex flex-col justify-between">
            <div class="w-16 h-16 rounded-full border border-white/20 flex items-center justify-center mb-12">
              <i class="ph-light ph-shield-check text-3xl text-cyan-300"></i>
            </div>
            <div>
              <h3 class="text-3xl lg:text-4xl font-bold mb-4 text-cyan-300">Verified Opportunities</h3>
              <p class="text-slate-300 text-lg lg:text-xl font-light max-w-md">We rigorously vet every partner, institution, and employer to provide you with secure, authentic pathways abroad.</p>
            </div>
          </div>
        </div>

        <!-- Small Block 1 -->
        <div class="md:col-span-6 lg:col-span-5 bg-purple-50 rounded-3xl p-10 lg:p-12 border border-purple-100 group hover:bg-purple-100 transition-colors" data-aos="fade-up" data-aos-delay="100">
          <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center mb-8 shadow-sm text-purple-600">
            <i class="ph-light ph-globe-hemisphere-west text-2xl"></i>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-3">Global Network</h3>
          <p class="text-slate-600">Direct partnerships with embassies, universities, and multinational corporations.</p>
        </div>

        <!-- Small Block 2 -->
        <div class="md:col-span-6 lg:col-span-4 bg-amber-50 rounded-3xl p-10 lg:p-12 border border-amber-100 group hover:bg-amber-100 transition-colors" data-aos="fade-up" data-aos-delay="200">
          <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center mb-8 shadow-sm text-amber-600">
            <i class="ph-light ph-files text-2xl"></i>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-3">Visa Expertise</h3>
          <p class="text-slate-600">Meticulous document preparation resulting in an industry-leading approval rate.</p>
        </div>

        <!-- Medium Block -->
        <div class="md:col-span-12 lg:col-span-8 bg-white rounded-3xl p-10 lg:p-12 border border-slate-200 shadow-xl shadow-black/5 flex flex-col md:flex-row gap-8 items-center group relative overflow-hidden" data-aos="fade-up" data-aos-delay="300">
          <div class="absolute -right-20 -bottom-20 text-[15rem] text-slate-50 opacity-50 font-bold font-heading pointer-events-none select-none">24/7</div>
          <div class="relative z-10 flex-1">
            <div class="w-14 h-14 rounded-full bg-slate-900 flex items-center justify-center mb-8 text-white">
              <i class="ph-light ph-headset text-2xl"></i>
            </div>
            <h3 class="text-2xl lg:text-3xl font-bold text-slate-900 mb-4">Concierge-Level Support</h3>
            <p class="text-slate-600 text-lg">From the initial consultation to your arrival at your destination, our dedicated team provides uninterrupted, personalized assistance at every milestone.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- About Preview Section (Editorial) -->
  <section class="py-24 lg:py-32 bg-slate-50 relative overflow-hidden" id="about">
    <div class="absolute -right-40 top-20 text-[20rem] font-bold text-slate-100 font-heading select-none pointer-events-none z-0">PTC</div>
    
    <div class="container-custom relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-center">
        
        <!-- Image Column with Offset -->
        <div class="lg:col-span-5 relative pr-6 pb-6 lg:pr-0 lg:pb-0" data-aos="fade-right">
          <div class="relative z-10 w-full aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl">
            <img src="/images/travel_illus0.jpg" alt="Pleroma Team" class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-[1.5s] ease-out">
            <div class="absolute inset-0 bg-slate-900/10 mix-blend-multiply"></div>
          </div>
          <!-- Decorative Frame -->
          <div class="absolute -top-6 -left-6 w-full h-full border border-slate-300 rounded-[2rem] z-0 pointer-events-none"></div>
          <!-- Stats Badge -->
          <div class="absolute bottom-0 right-0 lg:-bottom-10 lg:-right-10 bg-white p-6 lg:p-8 rounded-3xl shadow-xl z-20 w-40 lg:w-48 border border-slate-100" data-aos="fade-up" data-aos-delay="200">
            <div class="text-3xl lg:text-4xl font-bold text-slate-900 mb-1 font-heading">98<span class="text-amber-500">%</span></div>
            <p class="text-xs lg:text-sm text-slate-500 font-medium uppercase tracking-widest">Success Rate</p>
          </div>
        </div>

        <!-- Content Column -->
        <div class="lg:col-span-7 lg:pl-10" data-aos="fade-left">
          <div class="flex items-center gap-4 mb-8">
            <span class="w-12 h-[2px] bg-slate-300"></span>
            <span class="text-slate-500 tracking-[0.2em] text-xs font-bold uppercase">Our Philosophy</span>
          </div>
          
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8 text-slate-900 leading-[1.1] tracking-tight font-heading">
            Redefining <span class="italic font-light text-slate-500">Global</span><br/> Mobility
          </h2>
          
          <p class="text-xl text-slate-600 mb-12 leading-relaxed font-light">
            We don't believe in one-size-fits-all solutions. Our approach marries deep regulatory knowledge with a personalized understanding of your ambitions, creating a seamless bridge to your international future.
          </p>

          <div class="space-y-8 mb-12 border-l border-slate-200 pl-8">
            <div class="relative">
              <div class="absolute -left-[2.1rem] top-1 w-2 h-2 rounded-full bg-slate-900"></div>
              <h4 class="text-xl font-bold text-slate-900 mb-2">Transparency</h4>
              <p class="text-slate-500 leading-relaxed font-light">We promise clarity and honesty in an industry that can often be confusing. No hidden fees or misleading timelines.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[2.1rem] top-1 w-2 h-2 rounded-full bg-slate-400"></div>
              <h4 class="text-xl font-bold text-slate-900 mb-2">High Approval Rates</h4>
              <p class="text-slate-500 leading-relaxed font-light">Meticulous document preparation resulting in an industry-leading approval rate for visas and business registrations.</p>
            </div>
          </div>
          
          <Button href="/about" class="px-10 py-4 uppercase tracking-[0.15em] text-sm bg-slate-900 text-white hover:bg-slate-800 rounded-none hover:translate-x-2 transition-transform">
            Discover Our Story
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Destinations (Editorial Style) -->
  <section class="py-24 lg:py-32 bg-white" id="country">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16" data-aos="fade-up">
        <div>
          <span class="inline-block px-4 py-1 rounded-full bg-slate-100 text-slate-800 font-bold text-xs mb-6 tracking-[0.2em] uppercase border border-slate-200">Global Reach</span>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.1] tracking-tight font-heading">
            Destinations of <br/> <span class="italic font-light text-slate-500">Choice</span>
          </h2>
        </div>
        <div class="max-w-md">
          <p class="text-lg text-slate-600 font-light">Explore top-tier jurisdictions recognized globally for their robust economies, world-class education, and unparalleled quality of life.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 lg:gap-8 auto-rows-[400px] lg:auto-rows-[450px]">
        <!-- Canada -->
        <div class="lg:col-span-4 group relative overflow-hidden bg-slate-100 cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-[1s]" data-aos="fade-up" data-aos-delay="0">
          <img src="https://images.unsplash.com/photo-1517935706615-2717063c2225?auto=format&fit=crop&w=800&q=80" alt="Canada" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110 filter brightness-90 group-hover:brightness-100">
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-700"></div>
          <div class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-white/70 tracking-[0.3em] text-xs font-bold uppercase">01</span>
              <div class="h-[1px] w-12 bg-white/30 group-hover:w-24 group-hover:bg-white transition-all duration-700"></div>
            </div>
            <h3 class="text-4xl font-bold text-white mb-2 font-heading tracking-tight">Canada</h3>
            <p class="text-slate-300 font-light opacity-0 h-0 group-hover:h-auto group-hover:opacity-100 group-hover:mt-4 transition-all duration-700">Top choice for permanent residency and high quality of life.</p>
          </div>
        </div>

        <!-- USA -->
        <div class="lg:col-span-4 group relative overflow-hidden bg-slate-100 cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-[1s]" data-aos="fade-up" data-aos-delay="100">
          <img src="/images/us.avif" alt="USA" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110 filter brightness-90 group-hover:brightness-100">
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-700"></div>
          <div class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-white/70 tracking-[0.3em] text-xs font-bold uppercase">02</span>
              <div class="h-[1px] w-12 bg-white/30 group-hover:w-24 group-hover:bg-white transition-all duration-700"></div>
            </div>
            <h3 class="text-4xl font-bold text-white mb-2 font-heading tracking-tight">United States</h3>
            <p class="text-slate-300 font-light opacity-0 h-0 group-hover:h-auto group-hover:opacity-100 group-hover:mt-4 transition-all duration-700">The premier destination for technological and business innovation.</p>
          </div>
        </div>

        <!-- UK -->
        <div class="lg:col-span-4 group relative overflow-hidden bg-slate-100 cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-[1s]" data-aos="fade-up" data-aos-delay="200">
          <img src="https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?auto=format&fit=crop&w=800&q=80" alt="United Kingdom" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110 filter brightness-90 group-hover:brightness-100">
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-700"></div>
          <div class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-white/70 tracking-[0.3em] text-xs font-bold uppercase">03</span>
              <div class="h-[1px] w-12 bg-white/30 group-hover:w-24 group-hover:bg-white transition-all duration-700"></div>
            </div>
            <h3 class="text-4xl font-bold text-white mb-2 font-heading tracking-tight">United Kingdom</h3>
            <p class="text-slate-300 font-light opacity-0 h-0 group-hover:h-auto group-hover:opacity-100 group-hover:mt-4 transition-all duration-700">Prestigious universities intertwined with a rich cultural heritage.</p>
          </div>
        </div>

        <!-- Australia -->
        <div class="lg:col-span-7 group relative overflow-hidden bg-slate-100 cursor-pointer shadow-lg hover:shadow-2xl transition-all duration-[1s]" data-aos="fade-up" data-aos-delay="300">
