---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Apply Now - Pleroma Travel Consult">
  <!-- Hero -->
  <header class="relative h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden pt-20">
    <div class="absolute inset-0 z-0">
      <img src="/images/student.webp" alt="Apply Now" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-[2px]"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto" data-aos="fade-up">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">Start Your Application</h1>
      <p class="text-lg md:text-xl text-slate-200 max-w-2xl mx-auto">Begin your journey to study or work abroad with our expert guidance.</p>
    </div>
  </header>

  <!-- Process -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block px-4 py-1 rounded-full bg-purple-50 text-purple-600 font-bold text-xs mb-4 tracking-wide uppercase border border-purple-100">Simple 3-Step Process</span>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900">How It Works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="relative p-8 rounded-3xl bg-white border border-slate-100 shadow-lg hover:shadow-xl transition-all group" data-aos="fade-up" data-aos-delay="0">
          <div class="absolute -top-6 left-8 w-12 h-12 bg-purple-600 rounded-2xl flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-purple-500/30">1</div>
          <div class="mt-8">
            <h3 class="text-xl font-bold text-slate-900 mb-3">Free Consultation</h3>
            <p class="text-slate-600 text-sm mb-6 leading-relaxed">Discuss your travel goals and options with our experts directly vs phone or WhatsApp.</p>
            <a href="https://wa.me/233558009078" class="inline-flex items-center text-purple-600 font-semibold text-sm hover:translate-x-1 transition-transform">Start Chat <i class="ph-bold ph-arrow-right ml-1"></i></a>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative p-8 rounded-3xl bg-white border border-slate-100 shadow-lg hover:shadow-xl transition-all group" data-aos="fade-up" data-aos-delay="100">
          <div class="absolute -top-6 left-8 w-12 h-12 bg-amber-500 rounded-2xl flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-amber-500/30">2</div>
          <div class="mt-8">
            <h3 class="text-xl font-bold text-slate-900 mb-3">Document Preparation</h3>
            <p class="text-slate-600 text-sm mb-6 leading-relaxed">We help you gather and review all necessary documents to ensure a high success rate.</p>
            <a href="/contact" class="inline-flex items-center text-amber-600 font-semibold text-sm hover:translate-x-1 transition-transform">Book Review <i class="ph-bold ph-arrow-right ml-1"></i></a>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative p-8 rounded-3xl bg-white border border-slate-100 shadow-lg hover:shadow-xl transition-all group" data-aos="fade-up" data-aos-delay="200">
          <div class="absolute -top-6 left-8 w-12 h-12 bg-blue-500 rounded-2xl flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-blue-500/30">3</div>
          <div class="mt-8">
            <h3 class="text-xl font-bold text-slate-900 mb-3">Application Submission</h3>
            <p class="text-slate-600 text-sm mb-6 leading-relaxed">Our team handles the submission and follows up on your behalf until approval.</p>
            <span class="inline-flex items-center text-blue-600 font-semibold text-sm">We handle the rest</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portal Section -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-3xl bg-gradient-to-br from-slate-900 to-slate-800 p-8 md:p-12 text-center text-white shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-full opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 bg-white/10 rounded-full flex items-center justify-center mx-auto mb-6 backdrop-blur-sm"><i class="ph-fill ph-lock-key text-3xl text-amber-400"></i></div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Secure Client Portal</h2>
          <p class="text-slate-300 max-w-2xl mx-auto mb-10">Existing clients can log in to track application status, upload documents securely, and communicate with their case manager.</p>
          
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10 text-left max-w-3xl mx-auto">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0"><i class="ph ph-file-text text-amber-400"></i></div>
              <span class="text-sm font-medium">Digital Forms</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0"><i class="ph ph-cloud-arrow-up text-amber-400"></i></div>
              <span class="text-sm font-medium">Secure Upload</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0"><i class="ph ph-chart-line-up text-amber-400"></i></div>
              <span class="text-sm font-medium">Live Tracking</span>
            </div>
          </div>

          <a href="#" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full bg-amber-500 text-white font-bold hover:bg-amber-600 transition-all shadow-lg shadow-amber-500/20 transform hover:-translate-y-1">
            Access Client Portal <i class="ph-bold ph-arrow-right"></i>
          </a>
          <p class="text-xs text-slate-500 mt-4">Restricted access for registered clients only.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Requirements Grid -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">General Requirements</h2>
        <p class="text-slate-600">Have these documents ready to speed up your process</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 flex flex-col items-center text-center hover:border-purple-200 transition-colors">
          <i class="ph-fill ph-identification-card text-3xl text-purple-600 mb-3"></i>
          <h4 class="font-bold text-slate-900 text-sm">Ghana Card</h4>
          <p class="text-xs text-slate-500 mt-1">Valid ID Copy</p>
        </div>
        <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 flex flex-col items-center text-center hover:border-purple-200 transition-colors">
          <i class="ph-fill ph-passport text-3xl text-purple-600 mb-3"></i>
          <h4 class="font-bold text-slate-900 text-sm">Passport</h4>
          <p class="text-xs text-slate-500 mt-1">Bio Data Page</p>
        </div>
        <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 flex flex-col items-center text-center hover:border-purple-200 transition-colors">
          <i class="ph-fill ph-image text-3xl text-purple-600 mb-3"></i>
          <h4 class="font-bold text-slate-900 text-sm">Photo</h4>
          <p class="text-xs text-slate-500 mt-1">Passport Size</p>
        </div>
        <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 flex flex-col items-center text-center hover:border-purple-200 transition-colors">
          <i class="ph-fill ph-file-text text-3xl text-purple-600 mb-3"></i>
          <h4 class="font-bold text-slate-900 text-sm">CV / Resume</h4>
          <p class="text-xs text-slate-500 mt-1">Updated Copy</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
