---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Legal Document Services - Pleroma Travel Consult" activeNav="services">
  <!-- Premium Hero Section -->
  <header class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 bg-slate-900 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0 bg-slate-900">
      <img src="/images/passport.jpg" alt="Legal Documents" class="w-full h-full object-cover opacity-50 object-center">
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/95 via-slate-900/70 to-slate-900/30"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-aos="fade-right">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-[2px] bg-indigo-500"></div>
          <span class="text-indigo-500 font-bold text-xs tracking-widest uppercase">Legal & Compliance</span>
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-white mb-6 tracking-tight leading-tight">
          Document Services
        </h1>
        <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl">
          Hassle-free, meticulous processing for Passports, Birth Certificates, and legal document authentication.
        </p>
      </div>
    </div>
  </header>

  <!-- Services Section -->
  <section class="py-24 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">
      
      <!-- Passport Service (Text Left, Image Right) -->
      <div class="flex flex-col-reverse lg:flex-row gap-12 lg:gap-16 items-center" id="passport">
        <!-- Content -->
        <div class="lg:w-1/2" data-aos="fade-right">
          <div class="flex items-center gap-4 mb-6">
            <span class="w-12 h-[2px] bg-indigo-300"></span>
            <span class="text-indigo-500 tracking-[0.2em] text-xs font-bold uppercase">Travel Documentation</span>
          </div>
          
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-slate-900 leading-[1.1] tracking-tight font-heading">
            Passport <span class="italic font-light text-slate-500">Services</span>
          </h2>
          
          <p class="text-lg text-slate-600 mb-8 leading-relaxed font-light">
            We guide you through every step of the passport application process, ensuring your documents are compliant, accurate, and submitted on time to avoid unnecessary delays.
          </p>

          <div class="space-y-6 border-l border-slate-200 pl-6">
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-indigo-500"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">New Applications</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">End-to-end support for first-time passport applicants.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-blue-400"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Renewal & Replacement</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">Fast-tracked processing for expired or lost passports.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-slate-800"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Biometric Appointments</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">Priority scheduling for your biometric data capture.</p>
            </div>
          </div>
        </div>

        <!-- Image -->
        <div class="lg:w-1/2 w-full" data-aos="fade-left">
          <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-lg border border-slate-100 relative group">
            <div class="absolute inset-0 bg-indigo-900/10 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
            <img src="/images/passport0.jpg" alt="Passport" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700">
          </div>
        </div>
      </div>

      <!-- Birth Cert Service (Image Left, Text Right) -->
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-center" id="birth-certificate">
        <!-- Image -->
        <div class="lg:w-1/2 w-full order-2 lg:order-1" data-aos="fade-right">
          <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-lg border border-slate-100 relative group">
            <div class="absolute inset-0 bg-amber-900/10 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
            <img src="/images/bcert.jpg" alt="Legal Document" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700">
          </div>
        </div>

        <!-- Content -->
        <div class="lg:w-1/2 order-1 lg:order-2" data-aos="fade-left">
          <div class="flex items-center gap-4 mb-6">
            <span class="w-12 h-[2px] bg-amber-300"></span>
            <span class="text-amber-800 tracking-[0.2em] text-xs font-bold uppercase">Civil Registry</span>
          </div>
          
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-slate-900 leading-[1.1] tracking-tight font-heading">
            Birth Certificate <span class="italic font-light text-slate-500">Assistance</span>
          </h2>
          
          <p class="text-lg text-slate-600 mb-8 leading-relaxed font-light">
            We help you navigate the Registrar General's Department protocols to obtain, verify, or authenticate your essential birth records seamlessly.
          </p>

          <div class="space-y-6 border-l border-slate-200 pl-6">
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-amber-800"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">New Registration</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">Standard and late registration processing assistance.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-amber-600"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Certified True Copies</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">Official duplicates for legal and travel purposes.</p>
            </div>
            <div class="relative">
              <div class="absolute -left-[1.6rem] top-1.5 w-1.5 h-1.5 rounded-full bg-slate-800"></div>
              <h4 class="text-lg font-bold text-slate-900 mb-1">Authentication & Legalization</h4>
              <p class="text-slate-500 text-sm leading-relaxed font-light">Ministry of Foreign Affairs validation protocols.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Requirements Section (Tabbed Ledger) -->
  <section class="py-16 lg:py-20 bg-white border-t border-slate-100 relative" x-data="{ activeTab: 'passport' }">
    <div class="container-custom">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        
        <!-- Left Context & Tabs -->
        <div class="lg:w-1/3" data-aos="fade-right">
          <div class="sticky top-32">
            <span class="inline-flex items-center gap-2 text-indigo-600 text-xs font-bold tracking-[0.2em] uppercase mb-4">
              <i class="ph-bold ph-folder-notch-open"></i> What You Need
            </span>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 leading-[1.1] tracking-tight font-heading mb-4">
              Preparation <span class="italic font-light text-slate-500">Checklist</span>
            </h2>
            <p class="text-base text-slate-600 font-light mb-8">
              Ensure you have the following prerequisites ready to expedite your processing timeline.
            </p>

            <!-- Tab Buttons -->
            <div class="flex flex-col gap-3">
              <button @click="activeTab = 'passport'" 
                      :class="activeTab === 'passport' ? 'bg-indigo-600 text-white shadow-md border-indigo-600' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'"
                      class="flex items-center justify-between px-6 py-4 rounded-xl font-bold transition-all border text-left">
                <span class="flex items-center gap-3">
                  <i class="ph-bold ph-identification-card text-xl"></i> Passport
                </span>
                <i class="ph-bold ph-arrow-right opacity-50" x-show="activeTab === 'passport'"></i>
              </button>

              <button @click="activeTab = 'birthcert'" 
                      :class="activeTab === 'birthcert' ? 'bg-amber-800 text-white shadow-md border-amber-800' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'"
                      class="flex items-center justify-between px-6 py-4 rounded-xl font-bold transition-all border text-left">
                <span class="flex items-center gap-3">
                  <i class="ph-bold ph-scroll text-xl"></i> Birth Certificate
                </span>
                <i class="ph-bold ph-arrow-right opacity-50" x-show="activeTab === 'birthcert'" x-cloak></i>
              </button>
            </div>
          </div>
        </div>

        <!-- Ledger Lists (Right Pane) -->
        <div class="lg:w-2/3" data-aos="fade-left">
          
          <!-- Passport Ledger -->
          <div x-show="activeTab === 'passport'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0">
            <div class="border-t-2 border-slate-900">
              {[
                { title: 'Completed Application Form', desc: 'Filled accurately without alterations.' },
                { title: 'Ghana Card or Valid ID', desc: 'Original and high-quality photocopies.' },
                { title: 'Recent Passport Photos', desc: 'Meeting standard biometric specifications.' },
                { title: 'Birth Certificate', desc: 'Required for all new passport applications.' }
              ].map((req, i) => (
                <div class="group py-4 sm:py-5 border-b border-slate-200 flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 hover:bg-slate-50 transition-colors px-4 sm:px-6 -mx-4 sm:-mx-6">
                  <div class="hidden sm:block text-slate-300 font-mono text-sm tracking-widest group-hover:text-indigo-500 transition-colors">0{i + 1}</div>
                  <div class="flex-1">
                    <h4 class="text-lg sm:text-xl font-bold text-slate-900 font-heading group-hover:text-indigo-700 transition-colors m-0">{req.title}</h4>
                    <p class="text-sm text-slate-500 mt-1 font-light">{req.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Birth Cert Ledger -->
          <div x-show="activeTab === 'birthcert'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" x-cloak>
            <div class="border-t-2 border-slate-900">
              {[
                { title: 'Parents\' Identification', desc: 'Valid IDs of both mother and father.' },
                { title: 'Hospital Weighing Card/Record', desc: 'Or clinic record of birth if available.' },
                { title: 'Witness Affidavit', desc: 'Compulsory for late registration processes.' },
                { title: 'Statutory Processing Fee', desc: 'Varies by service type and urgency.' }
              ].map((req, i) => (
                <div class="group py-4 sm:py-5 border-b border-slate-200 flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 hover:bg-slate-50 transition-colors px-4 sm:px-6 -mx-4 sm:-mx-6">
                  <div class="hidden sm:block text-slate-300 font-mono text-sm tracking-widest group-hover:text-amber-600 transition-colors">0{i + 1}</div>
                  <div class="flex-1">
                    <h4 class="text-lg sm:text-xl font-bold text-slate-900 font-heading group-hover:text-amber-800 transition-colors m-0">{req.title}</h4>
                    <p class="text-sm text-slate-500 mt-1 font-light">{req.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- CTA aligned with Ledger -->
          <div class="mt-12 text-left">
            <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-slate-900 text-white font-bold uppercase tracking-widest text-xs hover:bg-slate-800 transition-colors shadow-lg rounded-xl">
              Get Yours <i class="ph-bold ph-arrow-right"></i>
            </a>
          </div>

        </div>

      </div>
    </div>
  </section>
</BaseLayout>
